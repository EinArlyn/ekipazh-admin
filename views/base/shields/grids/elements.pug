extends ../../layout

block content
  .main-nav
    .nav-link
      a(href="/")= i18n.__('Dashboard') 
      span#nav-text
        =i18n.__('Elements')
      a(href="/base/shields/grids/profiles")=i18n.__('Profiles')
      a(href="/base/shields/grids/grids")=i18n.__('Mosquito nets')
      a(href="/base/shields/grids/systems")=i18n.__('Profile systems')
      a(href="/base/shields/grids/colors")=i18n.__('Color')
      a(href="/base/shields/grids/colorPrices")=i18n.__('pls_color_prices')
      a(href="/base/shields/grids/templates")=i18n.__('Template')
      img.loader-ico(src="/assets/images/loader_ico.GIF")
  .main-content
    .btn-add-element
      =i18n.__('Add element')
    .elements-list
      .element-row(style="font-weight: bold;")
        .element-content 
          .element-name
            =i18n.__('Name')
          .element-article
            =i18n.__('SKU')
          .element-price
            =i18n.__('Price')
          .element-unit-type
            =i18n.__('unit_short')
          .element-weight
            =i18n.__('Weight (kg)')
        .btns-block
          
      if (elements.length > 0)
       each elem in elements
        .element-row
          .element-content 
            .element-name
              =elem.name
            .element-article
              =elem.sku
            .element-price
              =elem.price + (elem.currency_id === 102 ? ' ₴' : elem.currency_id === 685 ? ' $' : elem.currency_id === 684 ? ' €' : '')
            .element-unit-type
              =(elem.unit_type_id === 1 ? i18n.__('pcs') : elem.unit_type_id === 2 ? i18n.__('m') : elem.unit_type_id === 3 ? i18n.__('sq. m') : elem.unit_type_id === 4 ? i18n.__('unit_kg') : elem.unit_type_id === 5 ? i18n.__('Perimeter2') : '')
            .element-weight
              =elem.weight + ' ' + i18n.__('unit_kg')
          .btns-block
            .btn-edit-item(data-element=elem.id)
            .btn-delete-item(data-element=elem.id)
            .btn-show-more(data-element=elem.id)
        
        .elements-elements(data-element=elem.id style="display: none;")
          .wrap
            .elements-info-text
              =i18n.__('Elements') + ': '
            .add-element-to-element(data-element=elem.id)
              =i18n.__('Add element')
          .elements-elements-header
            .elements-elements-content
              .elements-elements-name
                =i18n.__('Name')
              .elements-elements-article
                =i18n.__('SKU')
              .elements-elements-rules-name
                =i18n.__('Rule')
              .elements-elements-rules-value
                =i18n.__('Value')
            .btns-block
          if (elem.elements.length > 0)
            each subElem in elem.elements
              .elements-elements-row
                .elements-elements-content
                  .elements-elements-name
                    =subElem.name
                  .elements-elements-article
                    =subElem.sku
                  .elements-elements-rules-name
                    =rulesData[subElem.rules_id - 1] ? rulesData[subElem.rules_id - 1].name : 'Ошибка правила'
                  .elements-elements-rules-value
                    =subElem.rules_value
                .btns-block
                  .btn-edit-item(data-element=elem.id, data-sub-element=subElem.id)
                  .btn-delete-item(data-element=elem.id, data-sub-element=subElem.id)
  include popups/add_element.pug
  include popups/edit_element.pug
  include popups/delete_element.pug
  include popups/add_link_element.pug
  include popups/edit_link_element.pug
  include popups/delete_link_element.pug
  