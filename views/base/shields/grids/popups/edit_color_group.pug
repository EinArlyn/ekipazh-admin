.pop-up.pop-up-pls#popup-edit-color-group-pls
  form#edit-color-group-pls-form(method="POST" action="/base/shields/grids/colors/editColorGroup" enctype="multipart/form-data")
    input(type="hidden" name="group_id" value='' required)
    .pop-up-close-wrap
      a(class="pop-up-close", href="#")
    span.pop-up-header
      =i18n.__('Edit')

    .pop-up-pls-rows 
      .row-name.pls-row 
        .title-name.title
          =i18n.__('Name')
          | :
        input.input-default.text-name(type="text" value="" name="name" required)
      .row-position.pls-row 
        .title-position.title
          =i18n.__('Position')
          | :
        input.input-default.text-position(style="width: 50px;" type="number" value="" name="position" required)
      .row-description
        .title-description
          =i18n.__('Description')
          | :
        textarea.input-default.text-description(name="description")
    .row.block-center.text-center
      input.btn-submit(type="submit" value=i18n.__('Save'))
