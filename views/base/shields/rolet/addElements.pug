extends ../../layout

block content
  .main-nav
    .nav-link
      a(href="/")=i18n.__('Dashboard') 
      a(href="/base/shields/rolet/rolet")=i18n.__('rol_boxes')
      a(href="/base/shields/rolet/guides")=i18n.__('rol_guides')
      a(href="/base/shields/rolet/endLists")=i18n.__('rol_endcaps')
      a(href="/base/shields/rolet/lamels")=i18n.__('rol_slats')
      a(href="/base/shields/rolet/roletColorsGroups")=i18n.__('rol_colors')
      a(href="/base/shields/rolet/roletPrice")=i18n.__('rol_prices')
      a(href="/base/shields/rolet/roletBoxHeight")=i18n.__('rol_height')
      a(href="/base/shields/rolet/controls")=i18n.__('rol_control')
      a(href="/base/shields/rolet/controlBoxSizes")=i18n.__('rol_mapping')
      span#nav-text
        =i18n.__('Add. elements')
      img.loader-ico(src="/assets/images/loader_ico.GIF")
  .main-content    
    .titel-page 
      //- ='Add Elements :'  
    .block-systems.block-add-elements
      if (addElements && addElements.length > 0)
        each elem in addElements
          .rolet-add-elem-item
            .system-img
              img(src=(elem.img ? elem.img : '/local_storage/default.png'), alt="")
            .system-name
              =i18n.__('Name')
              = " : "
              =elem.name
            .system-price
              =i18n.__('Price')
              = " : "
              =elem.price
            .system-rule
              =i18n.__('unit_short')
              = " : "
              if (elem.rule === 1)
                =i18n.__('pcs')
              if (elem.rule === 2)
                =i18n.__('m')
              if (elem.rule === 3)
                =i18n.__('sq. m')
              if (elem.rule === 4)
                =i18n.__('unit_kg')
              if (elem.rule === 5)
                =i18n.__('mm')
              if (elem.rule === 6)
                =i18n.__('unit_cm')
            .btns-block-item
              .btn-active-system.btn-active(data-elem=elem.id class=!elem.is_activ ? 'btn-unactive' : 'btn-active')  
              .btn-edit-system.btn-system(data-elem=elem.id)
              .btn-delete-system.btn-system(data-elem=elem.id)
      .rolet-add-elem-item.btn-add-system
        div
          ='+'
        .btn-add-text 
          =i18n.__('Add')
  include popups/add-add-element.pug
  include popups/edit-add-element.pug
  include popups/delete-add-element.pug
  