extends ../../layout

block content
  .main-nav
    .nav-link
      a(href="/")=i18n.__('Dashboard') 
      a(href="/base/shields/rolet/rolet")=i18n.__('rol_boxes')
      a(href="/base/shields/rolet/guides")=i18n.__('rol_guides')
      a(href="/base/shields/rolet/endLists")=i18n.__('rol_endcaps')
      a(href="/base/shields/rolet/lamels")=i18n.__('rol_slats')
      a(href="/base/shields/rolet/roletColorsGroups")=i18n.__('rol_colors')
      a(href="/base/shields/rolet/roletPrice")=i18n.__('rol_prices')
      span#nav-text
        =i18n.__('rol_height')
      a(href="/base/shields/rolet/controls")=i18n.__('rol_control')
      a(href="/base/shields/rolet/controlBoxSizes")=i18n.__('rol_mapping')
      a(href="/base/shields/rolet/addElements")=i18n.__('Add. elements')
      img.loader-ico(src="/assets/images/loader_ico.GIF")
  .main-content    
    .titel-page 
      //- ='RoletBoxHeight :'  
    .box-height-table 
      .lamels-box 
        .header-box
        each lamel in lamels
          .lamel-row(data-id=lamel.id)
            .lamel-name 
              =lamel.name
            .types
              .type-not
                =' '
              .type-is
                =' '
      .groups-box 
        each group in groups
          .group-wrap 
            .group-box-name
              span 
                =group.group.name
            .boxes-box
              each box in group.boxes
                .box-box(data-box-id=box.id)
                  .box-name 
                    =box.name 
                  each box_size in box.sizes
                    .box-size 
                      .box-size-name
                        =box_size.height
                        =' / '
                        =box_size.width
                      each lam in lamels 
                        .field-type-not 
                          input.input-default.rolet-height-input(type="number" data-lamel-id=lam.id data-box-id=box.id data-size-id=box_size.id value="" name="")         
                        .field-type-is 
                          input.input-default.rolet-height-input(type="number" data-lamel-id=lam.id data-box-id=box.id data-size-id=box_size.id value="" name="")                 
                      
    