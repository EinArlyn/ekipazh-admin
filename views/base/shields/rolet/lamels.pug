extends ../../layout

block content
  .main-nav
    .nav-link
      a(href="/")=i18n.__('Dashboard') 
      a(href="/base/shields/rolet/rolet")=i18n.__('rol_boxes')
      a(href="/base/shields/rolet/guides")=i18n.__('rol_guides')
      a(href="/base/shields/rolet/endLists")=i18n.__('rol_endcaps')
      span#nav-text
        =i18n.__('rol_slats')
      a(href="/base/shields/rolet/roletColorsGroups")=i18n.__('rol_colors')
      a(href="/base/shields/rolet/roletPrice")=i18n.__('rol_prices')
      a(href="/base/shields/rolet/roletBoxHeight")=i18n.__('rol_height')
      a(href="/base/shields/rolet/controls")=i18n.__('rol_control')
      a(href="/base/shields/rolet/controlBoxSizes")=i18n.__('rol_mapping')
      a(href="/base/shields/rolet/addElements")=i18n.__('Add. elements')
  .main-content    
    .titel-page 
      //- ='Lamels :'  
    .block-systems.block-lamels
      if (lamelsList && lamelsList.length > 0)
        each lamel in lamelsList
          .rolet-system-item
            .system-img
              img(src=(lamel.img ? lamel.img : '/local_storage/default.png'), alt="")
            .system-name
              =lamel.name
            .btns-block-item
              .btn-active-system.btn-active(data-lamel=lamel.id class=!lamel.is_activ ? 'btn-unactive' : 'btn-active')  
              .btn-edit-system.btn-system(data-lamel=lamel.id)
              .btn-delete-system.btn-system(data-lamel=lamel.id)
      .rolet-system-item.btn-add-system
        div
          ='+'
        .btn-add-text 
          =i18n.__('Add +')
  include popups/add-new-lamel.pug
  include popups/edit-lamel.pug
  include popups/delete-lamel.pug
  